# ---- PostgreSQL ----
POSTGRES_PASSWORD=mclaw_dev_pass
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://mclaw:mclaw_dev_pass@localhost:5432/mclaw

# ---- Redis ----
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---- LLM ----
# LiteLLM 代理配置（推荐：使用自托管 LiteLLM Proxy 统一管理多模型）
LITELLM_API_BASE=http://47.236.230.183:4000
LITELLM_API_KEY=sk-master-123456
DEFAULT_MODEL=gemini/gemini-2.0-flash

# 直接使用厂商 key（不通过 LiteLLM 代理时使用）
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ---- 飞书 OAuth ----
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:3000/auth/feishu/callback
FEISHU_DOMAIN=feishu

# ---- JWT ----
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---- Perplexity (网络搜索) ----
PERPLEXITY_API_KEY=

# ---- 代理绕过（防止系统代理拦截内部服务）----
NO_PROXY=gateway.yw-aioa.com,open.feishu.cn,accounts.feishu.cn,open.larksuite.com,localhost,127.0.0.1,::1
no_proxy=gateway.yw-aioa.com,open.feishu.cn,accounts.feishu.cn,open.larksuite.com,localhost,127.0.0.1,::1

# ---- LangSmith (LangGraph 可观测性) ----
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=mini-claw

# ---- Crawl4AI (网页抓取) ----
# Crawl4AI 使用 Playwright 浏览器渲染网页，支持 JS 和反爬虫绕过
# 首次使用前需运行: python3 -m patchright install chromium
# 浏览器默认 headless 模式 + stealth mode，无需额外配置

# ---- Sandbox ----
SANDBOX_ENABLED=true
SANDBOX_IMAGE=mclaw-sandbox:latest
SANDBOX_MAX_ACTIVE=10
SANDBOX_IDLE_TIMEOUT_MINUTES=10

# ---- 定时任务调度器 ----
SCHEDULER_ENABLED=true
SCHEDULER_MAX_CONCURRENT_JOBS=3
SCHEDULER_JOB_TIMEOUT_SECONDS=120
SCHEDULER_MAX_CONSECUTIVE_ERRORS=5
